[Unit]
Description=Matrix Presence Updater
After=network.target

[Service]
Type=simple
User=shane
SyslogIdentifier=matrix-premid
WorkingDirectory=/opt/matrix-premid
Environment=PYTHONUNBUFFERED=1
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus

# Load environment variables
EnvironmentFile=/opt/matrix-premid/.env

ExecStart=/opt/matrix-premid/.venv/bin/python /opt/matrix-premid/matrix_premid.py
Restart=on-failure
RestartSec=120

[Install]
WantedBy=multi-user.target
